{
  "name": "crewbee-project-context",
  "version": "0.1.5",
  "description": "Lightweight project context layer for Agent Coding and CrewBee integration.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "main": "./opencode-plugin.mjs",
  "exports": {
    ".": "./opencode-plugin.mjs",
    "./server": "./opencode-plugin.mjs"
  },
  "bin": {
    "crewbee-project-context": "./bin/crewbee-project-context.js"
  },
  "files": [
    "dist/",
    "opencode-plugin.mjs",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "diagnostics": "node scripts/check-syntax.mjs && npm run build && node scripts/doctor-repo.mjs",
    "typecheck": "tsc --noEmit && npm run build && node scripts/check-types.mjs",
    "build": "node scripts/build.mjs",
    "pack:local": "npm run build && node scripts/pack-local.mjs",
    "install:local:user": "node scripts/install-local-user.mjs",
    "install:registry:user": "node ./bin/crewbee-project-context.js install --source registry",
    "test": "npm run build && node --test tests/*.test.js",
    "doctor": "node ./bin/crewbee-project-context.js doctor",
    "primer": "npm run build && node dist/src/cli/main.js primer"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.14.28",
    "@opencode-ai/sdk": "1.14.28",
    "yaml": "^2.8.2"
  }
}
