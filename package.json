{
  "name": "@crewbee/project-context",
  "version": "0.1.0",
  "description": "Lightweight project context layer for Agent Coding and CrewBee integration.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "crewbee-context": "src/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "diagnostics": "node scripts/check-syntax.mjs && node scripts/doctor-repo.mjs",
    "typecheck": "node scripts/check-types.mjs",
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.js",
    "doctor": "node src/cli/main.js doctor",
    "primer": "node src/cli/main.js primer"
  },
  "engines": {
    "node": ">=20"
  }
}
